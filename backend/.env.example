NODE_ENV=development
PORT=4000
# Single origin, or comma-separated for production + previews (no trailing slashes).
FRONTEND_URL=http://localhost:8080
# FRONTEND_URLS=https://app.vercel.app,https://preview-abc.vercel.app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/twist
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
COOKIE_SECURE=false
GCS_PROJECT_ID=your_project_id
GCS_BUCKET=your_bucket_name
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# First admin without SQL (only when zero admins exist). See README.
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
